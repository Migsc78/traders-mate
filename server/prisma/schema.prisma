generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WebsiteClass {
  NONE
  SOCIAL_ONLY
  DIRECTORY_ONLY
  PROPER
  PROPER_DEAD
}

enum WebsiteCheck {
  OK
  DEAD
  SKIPPED
  AMBIGUOUS
}

enum BizStatus {
  OPERATIONAL
  CLOSED_TEMPORARILY
  CLOSED_PERMANENTLY
  UNKNOWN
}

enum OutreachStatus {
  NEW
  SCREENED
  CONTACTED
  INTERESTED
  DEMO_SENT
  SOLD
  DEAD
  DO_NOT_CONTACT
}

enum DomainState {
  AVAILABLE
  TAKEN
  UNKNOWN
}

enum ClientStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageChannel {
  SMS
  WHATSAPP
  EMAIL
  SYSTEM
}

enum MissedCallStatus {
  PENDING
  QUALIFYING
  CONVERTED
  SPAM
  EXPIRED
}

// How missed calls are rescued after the greeting.
enum MissedCallMode {
  SMS_QUALIFY
  VOICEMAIL
}

enum Channel {
  WHATSAPP
  SMS
  BOTH
}

enum EnquiryStatus {
  ROUTED
  HELD
  FAILED
}

model Lead {
  id                 String         @id @default(cuid())
  placeId            String         @unique
  displayName        String
  occupation         String
  town               String
  formattedAddress   String?
  lat                Float?
  lng                Float?
  phone              String?
  phoneIsMobile      Boolean        @default(false)
  email              String?
  googleMapsUri      String?

  primaryType        String?
  editorialSummary   String?
  openingHours       String?        // JSON string[] of weekday lines
  googleReviews      Json?          // [{ author, text, rating, publishTime? }]

  websiteUri         String?
  websiteClass       WebsiteClass
  websiteCheck       WebsiteCheck   @default(SKIPPED)

  businessStatus     BizStatus      @default(UNKNOWN)
  rating             Float?
  userRatingCount    Int            @default(0)
  lastReviewAt       DateTime?
  photoCount         Int            @default(0)

  domainSuggested    String?
  domainAvailable    DomainState    @default(UNKNOWN)
  affiliateUrl       String?

  qualified          Boolean        @default(false)
  disqualifiedReason String?
  priorityScore      Int            @default(0)

  outreachStatus     OutreachStatus @default(NEW)
  tpsCheckedAt       DateTime?
  notes              String?

  siteSlug           String?
  siteGeneratedAt    DateTime?

  lastFetchedAt      DateTime       @default(now())
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  searchRunId        String?
  searchRun          SearchRun?     @relation(fields: [searchRunId], references: [id])

  @@index([occupation, town])
  @@index([qualified, priorityScore])
  @@index([websiteClass])
  @@index([outreachStatus])
}

model SearchRun {
  id          String   @id @default(cuid())
  occupation  String
  town        String?
  centerLat   Float?
  centerLng   Float?
  radiusM     Int?
  resultCount Int      @default(0)
  newCount    Int      @default(0)
  createdAt   DateTime @default(now())
  leads       Lead[]
}

// A converted client (the paying tradie) — the CRM tenant we route leads to.
model Client {
  id               String       @id @default(cuid())
  leadId           String?      @unique // origin prospect from the lead engine, if any — unique so a lead can't be converted twice
  businessName     String
  tradeTitle       String?
  town             String?
  addressLine1     String? // street address for invoices / business location
  addressLine2     String?
  postcode         String? // tradie's business postcode — used to compute distance to a lead's job
  vatNumber        String? // e.g. GB123456789 — shown on invoices when set
  routeKey         String       @unique // public key baked into the site/widget
  destPhone        String // tradie's own number (forwarding model), E.164 or 0-prefixed
  destChannel      Channel      @default(SMS)
  status           ClientStatus @default(ACTIVE)
  phoneVerifiedAt  DateTime?
  trialEndsAt      DateTime?
  twilioNumber     String? // dedicated Twilio number for missed-call divert
  twilioNumberSid  String? // Twilio IncomingPhoneNumber SID when auto-provisioned
  /// Setup wizard: 0 welcome … 6 get-paid; completed when onboardingCompletedAt set
  onboardingStep   Int          @default(0)
  onboardingCompletedAt DateTime?
  onboardingDivertConfirmedAt DateTime?
  onboardingTestCallAt DateTime?
  welcomeSmsSentAt DateTime?
  greetingAudioUrl String? // public URL Twilio/UI use to play the greeting
  greetingPlayToken String? @unique // /api/public/greeting/:token (survives redeploys)
  greetingAudioData Bytes? // WAV/MP3 bytes in Postgres — disk uploads are wiped on Railway redeploy
  greetingAudioMime String? // e.g. audio/wav
  missedCallMode   MissedCallMode @default(SMS_QUALIFY) // SMS Q&A vs leave a voicemail → job
  inboundEmailLocal String? @unique // local-part for inbound email intake
  bankName         String?
  bankSortCode     String?
  bankAccountName  String?
  bankAccountNumber String?
  stripeCustomerId String?
  stripeSubId      String?
  /// Stripe Connect Express account for customer invoice Pay Now
  stripeConnectAccountId String?
  stripeConnectOnboarded Boolean @default(false)
  /// Google review URL for post-job review SMS
  googleReviewUrl  String?
  /// Default deposit % on quotes (0 = off)
  defaultDepositPercent Int @default(0)
  allowedOrigins   String[]     @default([]) // domains permitted to POST via the widget
  tradieNotifyTpl  String? // custom message the tradie receives
  customerAckTpl   String? // custom auto-reply the customer sees
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  enquiries        Enquiry[]
  priceBookItems   PriceBookItem[]
  voiceNotes       VoiceNote[]
  quotes           Quote[]
  sessions         ClientSession[]
  assets           ClientAsset[]
  invoices         Invoice[]
  messages         Message[]
  missedCalls      MissedCall[]
  otpChallenges    OtpChallenge[]
  appointments     Appointment[]
  certificates     Certificate[]

  @@index([status])
  @@index([destPhone])
  @@index([twilioNumber])
}

enum TwilioPoolStatus {
  AVAILABLE
  ASSIGNED
}

/// Spare / inventory Twilio numbers — claim before buying a new one.
model TwilioNumberPool {
  id               String           @id @default(cuid())
  phoneNumber      String           @unique
  sid              String           @unique
  status           TwilioPoolStatus @default(AVAILABLE)
  assignedClientId String?          @unique
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([status])
}

// A routed customer enquiry (the actual lead delivered to a client).
model Enquiry {
  id           String        @id @default(cuid())
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name         String
  phone        String
  message      String?
  postcode     String? // customer's job postcode, if given
  distanceMiles Float? // computed distance from client.postcode, if both are known
  photoUrls    String[]      @default([])
  source       String        @default("site") // site | widget | hosted | qr
  status       EnquiryStatus @default(ROUTED)
  deliveredAt  DateTime?
  deliveryInfo String?
  createdAt    DateTime      @default(now())

  quotes       Quote[]
  voiceNotes   VoiceNote[]
  invoices     Invoice[]
  messages     Message[]
  missedCalls  MissedCall[]
  appointments Appointment[]
  certificates Certificate[]

  @@index([clientId, createdAt])
  @@index([clientId, phone])
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
  DELETED
}

enum VoiceNoteStatus {
  UPLOADED
  TRANSCRIBING
  READY
  FAILED
}

enum FollowUpKind {
  QUOTE_D2
  QUOTE_D5
  QUOTE_D10
  INVOICE_D3
  INVOICE_D7
  REVIEW_ASK
  REVIEW_NUDGE
  APPT_CONFIRM
  APPT_REMINDER
  SERVICE_REMINDER
}

enum FollowUpStatus {
  PENDING
  SENT
  SKIPPED
  CANCELLED
}

enum PriceUnit {
  EACH
  HOUR
  DAY
  JOB
  METRE
}

model PriceBookItem {
  id             String    @id @default(cuid())
  clientId       String
  client         Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sku            String?
  label          String
  tradeTag       String?
  unit           PriceUnit @default(JOB)
  unitPricePence Int
  vatRate        Float     @default(20)
  isCallout      Boolean   @default(false)
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  quoteLines     QuoteLine[]

  @@index([clientId, active])
}

model VoiceNote {
  id          String          @id @default(cuid())
  clientId    String
  client      Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  enquiryId   String?
  enquiry     Enquiry?        @relation(fields: [enquiryId], references: [id], onDelete: SetNull)
  audioUrl    String?
  transcript  String?
  status      VoiceNoteStatus @default(UPLOADED)
  durationSec Int?
  rawExtract  Json?
  error       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  quotes      Quote[]

  @@index([clientId, createdAt])
  @@index([enquiryId])
}

model Quote {
  id              String      @id @default(cuid())
  clientId        String
  client          Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  enquiryId       String?
  enquiry         Enquiry?    @relation(fields: [enquiryId], references: [id], onDelete: SetNull)
  voiceNoteId     String?
  voiceNote       VoiceNote?  @relation(fields: [voiceNoteId], references: [id], onDelete: SetNull)
  status          QuoteStatus @default(DRAFT)
  currency        String      @default("GBP")
  vatInclusive    Boolean     @default(true)
  subtotalPence   Int         @default(0)
  vatPence        Int         @default(0)
  totalPence      Int         @default(0)
  /// 0-100; deposit required on accept when > 0 and Connect ready
  depositPercent  Int         @default(0)
  depositPence    Int         @default(0)
  depositPaidAt   DateTime?
  depositStripeSessionId String?
  publicToken     String      @unique
  customerNote    String?
  assumptions     String?
  pdfUrl          String?
  sentAt          DateTime?
  decidedAt       DateTime?
  validUntil      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  lines           QuoteLine[]
  followUps       FollowUp[]
  invoices        Invoice[]

  @@index([clientId, status, createdAt])
  @@index([enquiryId])
}

model QuoteLine {
  id              String         @id @default(cuid())
  quoteId         String
  quote           Quote          @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  sort            Int            @default(0)
  label           String
  qty             Float          @default(1)
  unit            PriceUnit      @default(JOB)
  unitPricePence  Int
  vatRate         Float          @default(20)
  priceBookItemId String?
  priceBookItem   PriceBookItem? @relation(fields: [priceBookItemId], references: [id], onDelete: SetNull)
  source          String         @default("MANUAL") // VOICE | BOOK | MANUAL
  createdAt       DateTime       @default(now())

  @@index([quoteId])
}

model FollowUp {
  id             String         @id @default(cuid())
  quoteId        String?
  quote          Quote?         @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  invoiceId      String?
  invoice        Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  appointmentId  String?
  appointment    Appointment?   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  certificateId  String?
  certificate    Certificate?   @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  clientId       String?
  enquiryId      String?
  kind           FollowUpKind
  status         FollowUpStatus @default(PENDING)
  runAt          DateTime
  sentAt         DateTime?
  bodySnapshot   String?
  createdAt      DateTime       @default(now())

  @@index([status, runAt])
  @@index([quoteId])
  @@index([invoiceId])
  @@index([appointmentId])
  @@index([certificateId])
}

model ClientSession {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([clientId])
  @@index([expiresAt])
}

enum ClientAssetKind {
  LOGO
  SHOWCASE
  JOB
  OTHER
}

/// Brand + portfolio images for website generation and quotes.
model ClientAsset {
  id        String          @id @default(cuid())
  clientId  String
  client    Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  kind      ClientAssetKind @default(SHOWCASE)
  url       String
  filename  String?
  caption   String?
  sort      Int             @default(0)
  createdAt DateTime        @default(now())

  @@index([clientId, kind])
}

model Invoice {
  id                String        @id @default(cuid())
  clientId          String
  client            Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  enquiryId         String?
  enquiry           Enquiry?      @relation(fields: [enquiryId], references: [id], onDelete: SetNull)
  quoteId           String?
  quote             Quote?        @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  status            InvoiceStatus @default(DRAFT)
  publicToken       String        @unique
  customerName      String?
  customerPhone     String?
  currency          String        @default("GBP")
  vatInclusive      Boolean       @default(true)
  subtotalPence     Int           @default(0)
  vatPence          Int           @default(0)
  totalPence        Int           @default(0)
  /// Amount still due after deposits already collected
  amountDuePence    Int           @default(0)
  depositAppliedPence Int         @default(0)
  dueDate           DateTime?
  reference         String?
  bankName          String?
  bankSortCode      String?
  bankAccountName   String?
  bankAccountNumber String?
  customerNote      String?
  pdfUrl            String?
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  paidVia           String? // bank | stripe | manual
  sentAt            DateTime?
  paidAt            DateTime?
  paidReportedAt    DateTime?
  reviewAskedAt     DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  lines             InvoiceLine[]
  followUps         FollowUp[]

  @@index([clientId, status, createdAt])
  @@index([enquiryId])
  @@index([quoteId])
}

model InvoiceLine {
  id             String  @id @default(cuid())
  invoiceId      String
  invoice        Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  sort           Int     @default(0)
  label          String
  qty            Float   @default(1)
  unit           String  @default("JOB")
  unitPricePence Int
  vatRate        Float   @default(20)
  createdAt      DateTime @default(now())

  @@index([invoiceId])
}

model Message {
  id          String           @id @default(cuid())
  clientId    String
  client      Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  enquiryId   String?
  enquiry     Enquiry?         @relation(fields: [enquiryId], references: [id], onDelete: SetNull)
  direction   MessageDirection
  channel     MessageChannel   @default(SMS)
  toAddr      String
  fromAddr    String?
  body        String
  twilioSid   String?
  status      String           @default("sent")
  createdAt   DateTime         @default(now())

  @@index([clientId, createdAt])
  @@index([enquiryId, createdAt])
  @@index([toAddr])
}

model MissedCall {
  id            String          @id @default(cuid())
  clientId      String
  client        Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  callerPhone   String
  status        MissedCallStatus @default(PENDING)
  enquiryId     String?
  enquiry       Enquiry?        @relation(fields: [enquiryId], references: [id], onDelete: SetNull)
  conversation  Json?           // [{role, text, at}]
  callSid       String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([clientId, callerPhone, status])
  @@index([callerPhone, status])
}

model OtpChallenge {
  id         String   @id @default(cuid())
  clientId   String?
  client     Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  phone      String
  codeHash   String
  purpose    String   // signup | login
  payload    Json?    // signup draft fields before client exists
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([phone, purpose])
  @@index([expiresAt])
}

enum EarlyAccessStatus {
  PENDING
  APPROVED
  DENIED
}

model EarlyAccessRequest {
  id              String            @id @default(cuid())
  email           String
  phone           String
  occupation      String
  status          EarlyAccessStatus @default(PENDING)
  inviteTokenHash String?           @unique
  inviteExpiresAt DateTime?
  inviteSentAt    DateTime?
  inviteUsedAt    DateTime?
  reviewedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status, createdAt])
  @@index([email])
  @@index([phone])
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  ON_THE_WAY
  DONE
  CANCELLED
  NO_SHOW
}

model Appointment {
  id          String            @id @default(cuid())
  clientId    String
  client      Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  enquiryId   String?
  enquiry     Enquiry?          @relation(fields: [enquiryId], references: [id], onDelete: SetNull)
  title       String
  notes       String?
  startsAt    DateTime
  endsAt      DateTime
  status      AppointmentStatus @default(SCHEDULED)
  address     String?
  customerName String?
  customerPhone String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  followUps   FollowUp[]

  @@index([clientId, startsAt])
  @@index([enquiryId])
}

enum CertificateKind {
  GAS_SAFETY
  MINOR_WORKS
  EICR
}

enum CertificateStatus {
  DRAFT
  SIGNED
  SENT
}

model Certificate {
  id              String            @id @default(cuid())
  clientId        String
  client          Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  enquiryId       String?
  enquiry         Enquiry?          @relation(fields: [enquiryId], references: [id], onDelete: SetNull)
  kind            CertificateKind
  status          CertificateStatus @default(DRAFT)
  siteAddress     String?
  customerName    String?
  customerPhone   String?
  customerEmail   String?
  /// Form field values as JSON
  formData        Json              @default("{}")
  signatureDataUrl String?
  signedAt        DateTime?
  pdfUrl          String?
  publicToken     String            @unique
  serviceDueAt    DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  followUps       FollowUp[]

  @@index([clientId, kind, createdAt])
  @@index([enquiryId])
  @@index([serviceDueAt])
}

/// Platform key/value config (survives Railway redeploys; env still wins when set).
model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
