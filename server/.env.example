# --- Core ---
# Local Docker (optional): postgresql://postgres:postgres@localhost:5432/tradiesmate?schema=public
# Day-to-day: use Railway Postgres (same DB as staging/prod-dev).
DATABASE_URL="postgresql://postgres:CHANGE_ME@HOST:PORT/railway?schema=public"
PORT=4000
# Comma-separated browser origins allowed to call the API (CORS).
CLIENT_ORIGIN="http://localhost:5173,https://tradiesmate.co.uk"

# --- Google Places API (New) ---
GOOGLE_PLACES_API_KEY="your-key-here"
PLACES_MAX_QPS=8
ENABLE_REVIEW_RECENCY=false

# --- Website reachability check ---
WEBSITE_CHECK_TIMEOUT_MS=5000
WEBSITE_CHECK_CONCURRENCY=10

# --- Domain availability ---
# RDAP is free, needs no account, and is the right default for .co.uk (via Nominet).
DOMAIN_CHECK_PROVIDER="rdap"   # "rdap" | "ionos" | "off"

# Optional: IONOS developer API (only if DOMAIN_CHECK_PROVIDER=ionos). Set in .env, not Settings UI.
IONOS_API_KEY=""
IONOS_API_SECRET=""
IONOS_API_BASE="https://api.hosting.ionos.com"
IONOS_AVAILABILITY_PATH="/domains/v1/domainitems?domain={domain}"

# --- Inbound rate limit ---
SEARCH_RATE_WINDOW_MS=60000
SEARCH_RATE_MAX=20

# --- Lead routing / messaging (Phase 1-2) ---
PUBLIC_BASE_URL="http://localhost:4000"
INTAKE_RATE_WINDOW_MS=60000
INTAKE_RATE_MAX=30

# Twilio — also configurable in Settings UI (gear icon). Used for SMS/WhatsApp lead alerts.
# Leave blank to use the logging stub (the whole flow still works for demos).
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_SMS_FROM=""          # e.g. +447700900000
TWILIO_WHATSAPP_FROM=""     # e.g. +14155238886 (Twilio WhatsApp sender)

# Missed-call TTS + first SMS (also editable in CRM Settings gear icon)
# Voices: Polly.Amy (natural UK), Polly.Emma, Polly.Brian, Google.en-GB-Neural2-A, alice (robotic)
MISSED_CALL_SAY_VOICE="Polly.Amy"
MISSED_CALL_SAY_TEXT="Sorry we missed your call. We're texting you now so we can take your details."
MISSED_CALL_SMS_TEXT="Hi, this is {{businessName}}'s assistant — sorry we missed your call. What do you need doing and what's your postcode?"

# --- Quote AI (also configurable in Settings UI) ---
# Claude Haiku 4.5 extracts line items from voice transcripts / typed notes.
CLAUDE_API_KEY=""
ANTHROPIC_API_KEY=""         # alias accepted if CLAUDE_API_KEY blank
# Optional: OpenAI Whisper for mic recordings (typed notes work with Claude alone).
OPENAI_API_KEY=""
MAGIC_LINK_SECRET="change-me-in-production"
# Frontend URL baked into Twilio SMS magic links (/t/auth?token=...).
# Local: http://localhost:5173
# Railway/prod: https://tradiesmate.co.uk  (must NOT be localhost)
APP_PUBLIC_URL="http://localhost:5173"

# --- Stripe billing (auto-flips client status on payment) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""            # the recurring subscription price
STRIPE_SUCCESS_URL=""
STRIPE_CANCEL_URL=""

# Operator CRM protection (required in production).
# Prefer OPERATOR_ADMIN_PASSWORD for /admin/login (issues a 14-day session).
# OPERATOR_API_TOKEN still works as Bearer auth for scripts / API tooling.
OPERATOR_API_TOKEN=""
OPERATOR_ADMIN_PASSWORD=""

# Self-serve trial length (days)
TRIAL_DAYS=14

# Inbound email intake: local-part@INBOUND_EMAIL_DOMAIN
INBOUND_EMAIL_DOMAIN="in.tradiesmate.co.uk"
INBOUND_EMAIL_WEBHOOK_SECRET=""
