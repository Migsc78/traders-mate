{
  "name": "tradies-mate-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "npx tsc --noEmit -p tsconfig.json",
    "test": "tsx src/__tests__/pipeline.test.ts && tsx src/__tests__/site.test.ts",
    "test:site": "tsx src/__tests__/site.test.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed/seed.ts",
    "db:seed:wipe": "tsx prisma/seed/wipe.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.43",
    "@types/pdfkit": "^0.17.6",
    "bottleneck": "^2.19.5",
    "cors": "^2.8.6",
    "express": "^4.22.2",
    "express-rate-limit": "^7.5.1",
    "pdfkit": "^0.19.1",
    "prisma": "^5.22.0",
    "typescript": "^5.9.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "tsx": "^4.23.0"
  }
}
