# Local: leave unset (Vite proxies /api → localhost:4000).
# Production (Vercel): set to your Railway public API URL, no trailing slash.
# Example: https://traders-mate-production-xxxx.up.railway.app
VITE_API_BASE=

# Optional: same value as server OPERATOR_API_TOKEN (protects CRM API when set).
# Or set localStorage tm_operator_token in the browser.
VITE_OPERATOR_API_TOKEN=
