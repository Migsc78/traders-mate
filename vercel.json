{
  "installCommand": "npm install --prefix client",
  "buildCommand": "npm run build --prefix client",
  "outputDirectory": "client/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/q/:path*",
      "destination": "https://traders-mate-production.up.railway.app/q/:path*"
    },
    {
      "source": "/i/:path*",
      "destination": "https://traders-mate-production.up.railway.app/i/:path*"
    },
    {
      "source": "/cert/:path*",
      "destination": "https://traders-mate-production.up.railway.app/cert/:path*"
    },
    { "source": "/((?!api/|assets/).*)", "destination": "/index.html" }
  ]
}
